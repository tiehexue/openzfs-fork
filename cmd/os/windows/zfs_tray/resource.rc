#include <windows.h>   // defines DS_*, WS_*, etc.
#include <commctrl.h>  // (optional) if you use common controls
#include "resource.h"

// App icon (used for the EXE and for the tray at runtime)
IDI_APP        ICON "openzfs.ico"
IDI_APP_WARN   ICON "openzfs_warn.ico"
IDI_APP_ERR    ICON "openzfs_err.ico"
IDI_APP_SCRUB  ICON "openzfs_scrub.ico"

// Import
IDD_IMPORT DIALOGEX 0,0,500,330
STYLE DS_MODALFRAME | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_CENTER
CAPTION "OpenZFS — Import"
FONT 9, "Segoe UI"
BEGIN
    CONTROL "", IDC_LIST, "SysListView32", WS_TABSTOP | WS_BORDER | WS_VSCROLL | WS_HSCROLL | LVS_REPORT,
            7, 7, 486, 220
    CONTROL "Force",    IDC_CHK_FORCE,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 7,   234, 60, 10
    CONTROL "Read-only",IDC_CHK_READONLY, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 80,  234, 70, 10
    CONTROL "No mount", IDC_CHK_NOMOUNT,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 163, 234, 70, 10
    CONTROL "Load crypto keys", IDC_CHK_LOADKEYS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 246, 234, 105, 10
    LTEXT   "", IDC_STATUS, 7, 252, 360, 10
    PUSHBUTTON  "Refresh", IDC_BTN_REFRESH,  290, 246, 60, 14
    DEFPUSHBUTTON "Import", IDC_BTN_IMPORT,  356, 246, 60, 14
    PUSHBUTTON  "Close",   IDC_BTN_CLOSE,    423, 246, 60, 14
END

// Password
IDD_PASSPHRASE DIALOGEX 0, 0, 250, 80
STYLE DS_MODALFRAME | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_CENTER
CAPTION "Unlock dataset"
FONT 9, "Segoe UI"
BEGIN
    LTEXT       "Enter passphrase:", -1, 7, 7, 236, 10
    EDITTEXT    IDC_EDIT_PASSPHRASE, 7, 20, 236, 14, ES_PASSWORD | ES_AUTOHSCROLL
    CONTROL     "Show", IDC_SHOW, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 7, 40, 50, 10
    DEFPUSHBUTTON "OK", IDOK, 142, 56, 50, 14
    PUSHBUTTON  "Cancel", IDCANCEL, 193, 56, 50, 14
END

